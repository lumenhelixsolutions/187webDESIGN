# PostgreSQL connection string used by Prisma.
# The bundled docker-compose.yml provisions a matching local database:
#   docker compose up -d
# Leaving this UNSET is fine for a quick look — the demo runs in "preview
# mode" and the lead form acknowledges submissions without persisting them.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onep8seven?schema=public"
